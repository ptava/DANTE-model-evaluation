// Note: requires activation of dumpRefinementIndo in dynamicMeshDict
refinementInfo
{
    libs            ("libmyutilityFunctionObjects.so");
    type            refinementInfo;
    enabled         true;
    executeControl  timeStep;
    executeInterval $../controlDict!foRefinementInterval;
    writeControl    timeStep;
    executeAtStart  false;
    writeInterval   $../controlDict!foRefinementInterval;
    refinementParameters
    (
        "nCells"
        "nTotToRefine"
        "nTotRefined"
        "nTotUnrefined"
        "nAtMaxRefinement"
        "lowerLimit"
        "upperLimit"
    );
}


