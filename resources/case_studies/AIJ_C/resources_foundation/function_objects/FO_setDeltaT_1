setDeltaT
{
    libs            ("libutilityFunctionObjects.so");
    type            setTimeStep;
    enabled         true;

    deltaT
    {
        type            table;
        values
        (
            (0.25       1e-3)
            (1.9        5e-5)
        );
        interpolationScheme     linear;
        outOfBounds     clamp;
    }
}


