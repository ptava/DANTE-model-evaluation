refinementY2_from45to22
{
    type                surfaces;
    libs                ("libsampling.so");
    surfaceFormat       vtk;
    fields              ( sasRefineIndicator );
    startTime           $../controlDict!foHfStart2;
    endTime             $../controlDict!foHfEnd2;
    writeControl        runTime;
    executeAtStart      false;
    writeInterval       $../controlDict!foHfDeltaT;
    enabled             false;

    surfaces
    (
        yNormal
        {
            type        cuttingPlane;
            planeType   pointAndNormal;
            point       (0 0 0);
            normal      (0 1 0);
        }
    );
}


