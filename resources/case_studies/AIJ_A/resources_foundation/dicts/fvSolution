FoamFile
{
    format      ascii;
    class       dictionary;
    location    "system";
    object      fvSolution;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

solvers
{
    p
    {
        solver          GAMG;
        smoother        GaussSeidel;
        tolerance       1e-06;
        relTol          0.1;
    }
    pcorr
    {
        $p;
        relTol          0.0;
    }
    "(pFinal|pcorrFinal)"
    {
        solver          GAMG;
        smoother        GaussSeidel;
        tolerance       1e-06;
        relTol          0;
    }
    "(U|k|omega)"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-06;
        relTol          0.01;
    }
    "(U|k|omega)Final"
    {
        solver          smoothSolver;
        smoother        symGaussSeidel;
        tolerance       1e-05;
        relTol          0;
    }
}

PIMPLE
{
    consistent               yes;
    turbOnFinalIterOnly      no;
    nNonOrthogonalCorrectors 2;
    nOuterCorrectors         5; // controlled by FO_setOuterCorrectors (--> 1)
    nCorrectors              2;
    pRefCell                 0;
    pRefValue                0;
}

relaxationFactors
{
    fields
    {
        p                  0.99;
        pFinal             1;
    }
    equations
    {
        "(U|omega|k)"      0.99;
        "(U|omega|k)Final" 1;
    }

    // Example with pseudo-transient start-up (--> 1) 
    // Do not use patterns where you want update via FO_setRelaxationFactors
    // fields
    // {
    //     p          0.6;
    //     pFinal     0.9;
    // }
    // equations
    // {
    //     U          0.7;
    //     omega      0.7;
    //     k          0.7;
    //     UFinal     0.95;
    //     omegaFinal 0.9;
    //     kFinal     0.9;
    // }
}


