Description
    Sample instantaneous velocity components on a compact subset of the
    existing AIJ_A probes to analyze dominant roof-shear-layer and wake
    frequencies behind the square building.
\*---------------------------------------------------------------------------*/

probesSpectral
{
    type            probes;
    libs            ("libsampling.so");
    enabled         true;
    executeAtStart  false;
    fields          (U);
    startTime       $../controlDict!foSpecStart;
    endTime         $../controlDict!foSpecEnd;
    executeControl  timeStep;
    executeInterval 1;
    writeControl    timeStep;
    writeInterval   1;
    setFormat       csv;
    interpolationScheme cellPoint;

    probeLocations
    (
        (0.0   0.0   0.17)
        (0.04  0.0   0.17)
        (0.06  0.0   0.17)
        (0.10  0.0   0.17)
        (0.0  -0.05  0.10)
        (0.06 -0.05  0.10)
        (0.10 -0.05  0.10)
        (0.16  0.0   0.10)
        (0.16 -0.09  0.10)
    );
}

